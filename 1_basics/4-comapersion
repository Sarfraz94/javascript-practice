//normal same datatype comparision
console.log(2>1)  //true
console.log(5!=3)  // true
console.log(2==2)  //true

// diffrent types of datatype comparesion .... but java script here check valuse not datatype 
console.log("1"<3) //true 
console.log(1<"3")  //true


//checking null valuse but null will be less then or equal or grater value than one
console.log(null>0)   //false
console.log(null==0) //false
console.log(null<0)  //false
console.log(null<=0)  //true
console.log(null>=0)  // true
console.log(null>=1)   //false

//checking undefined values
console.log(undefined>=0)  //false 
console.log(undefined>0)   //false


// here is === which also check valuse and datatype and == check only value
console.log(1=="1") //true
console.log(1==="1") //false


